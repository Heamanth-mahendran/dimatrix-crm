# .env - Environment variables for Dimatrix CRM Backend
# Copy this file to .env and fill in your values

# ─── AI Configuration ───────────────────────────────────────────────────────

# Option 1: Ollama (FREE, runs locally - RECOMMENDED for FYP)
# Install Ollama: https://ollama.ai
# Then run: ollama pull llama3
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Option 2: Anthropic Claude API (paid, best quality)
# Get your key from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── App Configuration ──────────────────────────────────────────────────────
APP_SECRET_KEY=dimatrix-crm-secret-change-in-production
DEBUG=true
